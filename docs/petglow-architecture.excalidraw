      "x": 115,
      "y": 760,
      "width": 420,
      "height": 120,
      "text": "// 统一响应格式\n{\n  \"code\": 0,\n  \"msg\": \"ok\",\n  \"data\": { ... }\n}\n\n// 认证头\nAuthorization: Bearer <token>",
