      "y": 760,
      "width": 420,
      "height": 120,
      "text": "-- 公共字段（所有表必须）\nid BIGINT AUTO_INCREMENT PRIMARY KEY\ncreated_at DATETIME\nupdated_at DATETIME\nis_deleted TINYINT(1) DEFAULT 0\n\n-- 表名前缀: pet_ (单数命名)",
